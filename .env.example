# ─────────────────────────────────────────────────────────────
# Copie este arquivo para ".env" e preencha a sua chave.
# O arquivo .env NÃO deve ir para o Git (já está no .gitignore).
# ─────────────────────────────────────────────────────────────

# Chave da API da Anthropic (gere em https://console.anthropic.com/settings/keys)
# Começa com sk-ant-...  (deixe VAZIO aqui; a chave de verdade vai só no .env)
ANTHROPIC_API_KEY=

# Modelo (opcional). Padrão: claude-sonnet-4-6
# Alternativa mais barata/rápida: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# Máximo de tokens por resposta (opcional)
MAX_TOKENS=2048

# Porta do servidor (opcional)
PORT=3000
